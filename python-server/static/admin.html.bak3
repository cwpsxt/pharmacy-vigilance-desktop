			async loadDrugSummary() {
				this.drugSummaryLoading = true;
				try {
					const params = {
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					};
					const res = await axios.get('/api/data/analysis/drug-summary', { 
						params, 
						withCredentials: true 
					});
					this.drugSummaryData = res.data;
					
					// 处理表格数据
					this.processDrugSummaryTableData();
					
					// 加载图表数据
					await this.loadDrugSummaryCharts();
				} catch (e) {
					this.$message.error('加载药品汇总数据失败: ' + (e.response?.data?.message || '未知错误'));
					this.drugSummaryData = [];
					this.processDrugSummaryTableData();
				} finally {
					this.drugSummaryLoading = false;
