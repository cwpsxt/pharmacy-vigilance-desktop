			async loadDrugSummaryCharts() {
				try {
					const params = {
						month: this.analysisFilters.month
					};
					const res = await axios.get('/api/data/analysis/drug-summary-charts', { 
						params, 
						withCredentials: true 
					});
					this.drugSummaryChartData = res.data;
				} catch (e) {
					console.error('加载药品汇总图表数据失败:', e);
					this.drugSummaryChartData = {
						bar_chart: [],
						pie_chart: []
					};
				}
			},
			
			processDrugSummaryTableData() {
				const tableData = [...this.drugSummaryData];
				
				// 添加合计行
				if (tableData.length > 0) {
					let totalSevere = 0;
					let totalGeneral = 0;
					
					tableData.forEach(item => {
						totalSevere += item.严重 || 0;
						totalGeneral += item.一般 || 0;
					});
					
					tableData.push({
						drug_name: '合计',
						manufacturer: '',
						严重: totalSevere,
						一般: totalGeneral,
						total: totalSevere + totalGeneral,
						isTotal: true
					});
				}
				
				this.drugSummaryTableData = tableData;
			},
			
			exportDrugSummary() {
				try {
					// 构建导出URL
					const params = new URLSearchParams({
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					});
					
					const exportUrl = `/api/data/analysis/export-drug-summary?${params.toString()}`;
					
					// 创建隐藏的下载链接
					const link = document.createElement('a');
					link.href = exportUrl;
					link.style.display = 'none';
					document.body.appendChild(link);
					link.click();
					document.body.removeChild(link);
					
					this.$message.success('药品汇总数据导出任务已开始，请稍候下载');
				} catch (e) {
					this.$message.error('导出药品汇总数据失败: ' + (e.message || '未知错误'));
				}
			},
			
			exportAllTabs() {
				this.mergedExportLoading = true;
				try {
					// 构建导出URL
					const params = new URLSearchParams({
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					});
					
					const exportUrl = `/api/data/analysis/export-all-tabs?${params.toString()}`;
					
					// 创建隐藏的下载链接
					const link = document.createElement('a');
					link.href = exportUrl;
					link.style.display = 'none';
					document.body.appendChild(link);
					link.click();
					document.body.removeChild(link);
					
					this.$message.success('合并导出任务已开始，请稍候下载');
				} catch (e) {
					this.$message.error('合并导出失败: ' + (e.message || '未知错误'));
				} finally {
					// 延迟关闭loading，给用户足够的反馈时间
					setTimeout(() => {
						this.mergedExportLoading = false;
					}, 2000);
				}
			},
			
			// 密码修改相关方法
			validateConfirmPassword(rule, value, callback) {
				if (value !== this.passwordForm.newPassword) {
					callback(new Error('两次输入的密码不一致'));
				} else {
					callback();
				}
			},
			
			cancelPasswordChange() {
				this.showPasswordDialog = false;
				this.resetPasswordForm();
			},
			
			resetPasswordForm() {
				this.passwordForm = {
					currentPassword: '',
					newPassword: '',
					confirmPassword: ''
				};
				if (this.$refs.passwordForm) {
					this.$refs.passwordForm.clearValidate();
				}
			},
			
			// 工作量数据管理相关方法
			async loadWorkloadData() {
				try {
					const response = await axios.get('/api/workload/data', { withCredentials: true });
					if (response.data.success) {
						this.workloadData = response.data.data;
						// 初始化过滤数据为全部数据
						this.filterWorkloadData();
					}
				} catch (error) {
					console.error('加载工作量数据失败:', error);
				}
			},

			// 筛选工作量数据
			filterWorkloadData() {
				['sample', 'income', 'critical'].forEach(type => {
					let data = [...this.workloadData[type]];

					// 按年份筛选
					if (this.workloadQueryYear) {
						data = data.filter(item => item.year === this.workloadQueryYear);
					}

					// 按月份区间筛选（如果设置了起始月份或结束月份）
					if (this.workloadQueryMonthStart || this.workloadQueryMonthEnd) {
						data = data.map(item => {
							const filteredItem = { ...item };
							const start = this.workloadQueryMonthStart || 1;
							const end = this.workloadQueryMonthEnd || 12;

							// 计算区间内的总和
							let total = 0;
							for (let month = 1; month <= 12; month++) {
								if (month < start || month > end) {
									// 不在区间内的月份设为null（不显示）
									filteredItem[`month_${month}`] = null;
								} else {
									total += item[`month_${month}`] || 0;
								}
							}
							filteredItem.total = total;
							return filteredItem;
						});
					}

					this.filteredWorkloadData[type] = data;
				});

				// 重置分页到第一页
				['sample', 'income', 'critical'].forEach(type => {
					this.workloadPagination[type].currentPage = 1;
				});
			},

			// 重置筛选条件
			resetWorkloadFilter() {
				this.workloadQueryYear = null;
				this.workloadQueryMonthStart = null;
				this.workloadQueryMonthEnd = null;
				this.filterWorkloadData();
			},

			// 生成季度对比图表
			generateQuarterlyChart() {
				if (!this.visualQueryYear) {
					this.$message.warning('请选择年度');
					return;
				}
				if (!this.visualMonthStart || !this.visualMonthEnd) {
					this.$message.warning('请选择月份区间');
					return;
				}
				if (this.visualMonthStart > this.visualMonthEnd) {
					this.$message.warning('起始月份不能大于结束月份');
					return;
				}

				// 判断是否只选择了一个月
				const isSingleMonth = this.visualMonthStart === this.visualMonthEnd;

				if (isSingleMonth) {
					// 单月模式：统计当前月、上个月、去年同月
					const currentMonth = this.visualMonthStart;

					// 计算上个月
					let previousMonth, previousMonthYear;
					if (currentMonth === 1) {
						previousMonth = 12;
						previousMonthYear = this.visualQueryYear - 1;
					} else {
						previousMonth = currentMonth - 1;
						previousMonthYear = this.visualQueryYear;
					}

					// 去年同月
					const lastYearSameMonth = currentMonth;
					const lastYearSameYear = this.visualQueryYear - 1;

					// 生成样品测定量图表（单月模式）
					this.generateSampleChartByMonth(currentMonth, this.visualQueryYear, previousMonth, previousMonthYear, lastYearSameMonth, lastYearSameYear);

					// 生成收入图表（单月模式）
					this.generateIncomeChartByMonth(currentMonth, this.visualQueryYear, previousMonth, previousMonthYear, lastYearSameMonth, lastYearSameYear);
				} else {
					// 季度模式：原有逻辑
					// 定义季度划分
					const quarters = [
						{ name: '第一季度', months: [1, 2, 3], index: 1 },
						{ name: '第二季度', months: [4, 5, 6], index: 2 },
						{ name: '第三季度', months: [7, 8, 9], index: 3 },
						{ name: '第四季度', months: [10, 11, 12], index: 4 }
					];

					// 根据选择的月份区间确定当前季度
					let currentQuarter = null;
					for (let quarter of quarters) {
						if (quarter.months.includes(this.visualMonthStart) || quarter.months.includes(this.visualMonthEnd)) {
							currentQuarter = quarter;
							break;
						}
					}

					if (!currentQuarter) {
						this.$message.warning('无法确定季度');
						return;
					}

					// 计算上个季度
					let previousQuarter, previousYear;
					if (currentQuarter.index === 1) {
						previousQuarter = quarters[3]; // 第四季度
						previousYear = this.visualQueryYear - 1;
					} else {
						previousQuarter = quarters[currentQuarter.index - 2];
						previousYear = this.visualQueryYear;
					}

					// 去年同期
					const lastYearSameQuarter = currentQuarter;
					const lastYearSameYear = this.visualQueryYear - 1;

					// 生成样品测定量图表
					this.generateSampleChart(currentQuarter, previousQuarter, previousYear, lastYearSameQuarter, lastYearSameYear);

					// 生成收入图表
					this.generateIncomeChart(currentQuarter, previousQuarter, previousYear, lastYearSameQuarter, lastYearSameYear);
				}

				if (this.quarterlyChartData.length === 0 && this.incomeChartData.length === 0) {
					this.$message.warning('所选月份区间没有数据');
				}
			},

			// 生成项目图表
			generateProjectCharts() {
				if (!this.projectQueryYear) {
					this.$message.warning('请选择年度');
					return;
				}
				if (!this.projectQueryQuarter) {
					this.$message.warning('请选择季度');
					return;
				}

				// 定义季度划分
				const quarters = [
					{ name: '第一季度', months: [1, 2, 3] },
					{ name: '第二季度', months: [4, 5, 6] },
					{ name: '第三季度', months: [7, 8, 9] },
					{ name: '第四季度', months: [10, 11, 12] }
				];

				// 获取选中的季度
				const selectedQuarter = quarters[this.projectQueryQuarter - 1];

				// 生成项目收入图表
				this.generateProjectIncomeChart(selectedQuarter);

				// 生成项目样品测定量饼状图
				this.generateProjectSamplePieChart(selectedQuarter);

				if (this.projectIncomeChartData.length === 0 && this.projectSampleChartData.length === 0) {
					this.$message.warning('所选季度没有数据');
				}
			},

			// 生成危急值图表
			generateCriticalCharts() {
				if (!this.criticalQueryYear) {
					this.$message.warning('请选择年度');
					return;
				}
				if (!this.criticalQueryQuarter) {
					this.$message.warning('请选择季度');
					return;
				}

				// 定义季度划分
				const quarters = [
					{ name: '第一季度', months: [1, 2, 3] },
					{ name: '第二季度', months: [4, 5, 6] },
					{ name: '第三季度', months: [7, 8, 9] },
					{ name: '第四季度', months: [10, 11, 12] }
				];

				// 获取当前季度和上个季度
				const currentQuarter = quarters[this.criticalQueryQuarter - 1];
				let previousQuarter, previousYear;

				if (this.criticalQueryQuarter === 1) {
					// 如果是第一季度，上个季度是去年第四季度
					previousQuarter = quarters[3];
					previousYear = this.criticalQueryYear - 1;
				} else {
					// 否则是当前年的上一季度
					previousQuarter = quarters[this.criticalQueryQuarter - 2];
					previousYear = this.criticalQueryYear;
				}

				// 生成季度对比柱状图
				this.generateCriticalCompareChart(currentQuarter, previousQuarter, previousYear);

				// 生成当前季度项目分布饼状图
				this.generateCriticalProjectChart(currentQuarter);

				if (this.criticalCompareChartData.length === 0 && this.criticalProjectChartData.length === 0) {
					this.$message.warning('所选季度没有数据');
				}
			},

			// 生成危急值季度对比图表
			generateCriticalCompareChart(currentQuarter, previousQuarter, previousYear) {
				const chartData = [];
				let maxValue = 0;

				// 统计上个季度的危急值
				const previousYearData = this.workloadData.critical.filter(item => item.year === previousYear);
				let previousTotal = 0;
				previousYearData.forEach(item => {
					previousQuarter.months.forEach(month => {
						previousTotal += item[`month_${month}`] || 0;
					});
				});

				chartData.push({
					quarter: previousQuarter.name,
					value: previousTotal
				});
				maxValue = Math.max(maxValue, previousTotal);

				// 统计当前季度的危急值
				const currentYearData = this.workloadData.critical.filter(item => item.year === this.criticalQueryYear);
				let currentTotal = 0;
				currentYearData.forEach(item => {
					currentQuarter.months.forEach(month => {
						currentTotal += item[`month_${month}`] || 0;
					});
				});

				chartData.push({
					quarter: currentQuarter.name,
					value: currentTotal
				});
				maxValue = Math.max(maxValue, currentTotal);

				this.criticalCompareChartData = chartData;
				this.maxCriticalValue = maxValue;
			},

			// 生成危急值项目分布饼状图
			generateCriticalProjectChart(currentQuarter) {
				// 获取当前年度的危急值数据
				const currentYearData = this.workloadData.critical.filter(item => item.year === this.criticalQueryYear);

				// 按项目统计危急值数量
				const projectMap = new Map();
				const quarterMonths = currentQuarter.months;

				currentYearData.forEach(item => {
					const projectName = item.project_name;
					if (!projectMap.has(projectName)) {
						projectMap.set(projectName, 0);
					}

					// 累加季度的危急值数量
					quarterMonths.forEach(month => {
						const monthValue = item[`month_${month}`] || 0;
						projectMap.set(projectName, projectMap.get(projectName) + monthValue);
					});
				});

				// 转换为数组，过滤掉数量为0的项目，并计算总数
				const projectArray = Array.from(projectMap, ([projectName, count]) => ({
					projectName,
					count
				})).filter(item => item.count > 0);

				const totalCount = projectArray.reduce((sum, item) => sum + item.count, 0);

				if (totalCount === 0) {
					this.criticalProjectChartData = [];
					return;
				}

				// 计算每个项目的百分比和饼图路径
				let currentAngle = -90;

				const chartData = projectArray.map(item => {
					const percentage = (item.count / totalCount) * 100;
					const angle = (percentage / 100) * 360;

					const startAngle = currentAngle * Math.PI / 180;
					const endAngle = (currentAngle + angle) * Math.PI / 180;
					const radius = 100;

					const x1 = radius * Math.cos(startAngle);
					const y1 = radius * Math.sin(startAngle);
					const x2 = radius * Math.cos(endAngle);
					const y2 = radius * Math.sin(endAngle);

					const largeArcFlag = angle > 180 ? 1 : 0;
					const path = `M 0 0 L ${x1} ${y1} A ${radius} ${radius} 0 ${largeArcFlag} 1 ${x2} ${y2} Z`;

					const midAngle = (currentAngle + angle / 2) * Math.PI / 180;
					// 引导线起点（从饼图边缘外侧开始，增加3px间隙）
					const lineStartRadius = radius + 3;
					const lineStartX = lineStartRadius * Math.cos(midAngle);
					const lineStartY = lineStartRadius * Math.sin(midAngle);

					// 判断标签在左侧还是右侧
					const isRightSide = Math.cos(midAngle) > 0;

					// 引导线终点（直线延伸）
					const lineLength = 85; // 引导线长度
					const lineEndX = lineStartX + (isRightSide ? lineLength : -lineLength);
					const lineEndY = lineStartY;

					const labelX = isRightSide ? lineEndX + 5 : lineEndX - 5;
					const labelY = lineEndY + 4;
					const labelAlign = isRightSide ? 'start' : 'end';

					currentAngle += angle;

					return {
						projectName: item.projectName,
						count: item.count,
						percentage: percentage,
						path: path,
						lineStartX: lineStartX,
						lineStartY: lineStartY,
						lineEndX: lineEndX,
						lineEndY: lineEndY,
						labelX: labelX,
						labelY: labelY,
						labelAlign: labelAlign
					};
				});

				// 调整标签位置以防止重叠
				this.criticalProjectChartData = this.adjustPieChartLabels(chartData);
			},

			// 计算危急值柱子高度
			getCriticalBarHeight(value) {
				if (!this.maxCriticalValue || this.maxCriticalValue === 0) {
					return 30;
				}
				if (value === 0) {
					return 30;
				}
				const height = (value / this.maxCriticalValue) * 290;
				return Math.max(30, height);
			},

			// 生成样品测定量图表（单月模式）
			generateSampleChartByMonth(currentMonth, currentYear, previousMonth, previousMonthYear, lastYearSameMonth, lastYearSameYear) {
				// 获取各年度的样品测定量数据
				const currentYearData = this.workloadData.sample.filter(item => item.year === currentYear);
				const previousMonthYearData = this.workloadData.sample.filter(item => item.year === previousMonthYear);
				const lastYearData = this.workloadData.sample.filter(item => item.year === lastYearSameYear);

				let maxValue = 0;

				// 统计当前月
				let currentMonthTotal = 0;
				currentYearData.forEach(item => {
					currentMonthTotal += item[`month_${currentMonth}`] || 0;
				});
				maxValue = Math.max(maxValue, currentMonthTotal);

				// 统计上个月
				let previousMonthTotal = 0;
				previousMonthYearData.forEach(item => {
					previousMonthTotal += item[`month_${previousMonth}`] || 0;
				});
				maxValue = Math.max(maxValue, previousMonthTotal);

				// 统计去年同月
				let lastYearSameMonthTotal = 0;
				lastYearData.forEach(item => {
					lastYearSameMonthTotal += item[`month_${lastYearSameMonth}`] || 0;
				});
				maxValue = Math.max(maxValue, lastYearSameMonthTotal);

				this.quarterlyChartData = [{
					quarter: `${currentMonth}月`,
					currentQuarter: currentMonthTotal,
					previousQuarter: previousMonthTotal,
					lastYearSame: lastYearSameMonthTotal,
					currentQuarterName: `${currentMonth}月`,
					currentQuarterYear: currentYear,
					previousQuarterName: `${previousMonth}月`,
					previousQuarterYear: previousMonthYear,
					lastYearSameQuarterName: `去年${lastYearSameMonth}月`
				}];

				this.maxQuarterlyValue = maxValue;
			},

			// 生成样品测定量图表（季度模式）
			generateSampleChart(currentQuarter, previousQuarter, previousYear, lastYearSameQuarter, lastYearSameYear) {
				// 获取各年度的样品测定量数据
				const currentYearData = this.workloadData.sample.filter(item => item.year === this.visualQueryYear);
				const previousYearData = this.workloadData.sample.filter(item => item.year === previousYear);
				const lastYearData = this.workloadData.sample.filter(item => item.year === lastYearSameYear);

				let maxValue = 0;

				// 统计当前季度
				let currentQuarterTotal = 0;
				currentYearData.forEach(item => {
					currentQuarter.months.forEach(month => {
						currentQuarterTotal += item[`month_${month}`] || 0;
					});
				});
				maxValue = Math.max(maxValue, currentQuarterTotal);

				// 统计上个季度
				let previousQuarterTotal = 0;
				previousYearData.forEach(item => {
					previousQuarter.months.forEach(month => {
						previousQuarterTotal += item[`month_${month}`] || 0;
					});
				});
				maxValue = Math.max(maxValue, previousQuarterTotal);

				// 统计去年同期
				let lastYearSameQuarterTotal = 0;
				lastYearData.forEach(item => {
					lastYearSameQuarter.months.forEach(month => {
						lastYearSameQuarterTotal += item[`month_${month}`] || 0;
					});
				});
				maxValue = Math.max(maxValue, lastYearSameQuarterTotal);

				this.quarterlyChartData = [{
					quarter: currentQuarter.name,
					currentQuarter: currentQuarterTotal,
					previousQuarter: previousQuarterTotal,
					lastYearSame: lastYearSameQuarterTotal,
					currentQuarterName: currentQuarter.name,
					currentQuarterYear: this.visualQueryYear,
					previousQuarterName: previousQuarter.name,
					previousQuarterYear: previousYear,
					lastYearSameQuarterName: lastYearSameQuarter.name
				}];

				this.maxQuarterlyValue = maxValue;
			},

			// 生成收入图表（单月模式）
			generateIncomeChartByMonth(currentMonth, currentYear, previousMonth, previousMonthYear, lastYearSameMonth, lastYearSameYear) {
				// 获取各年度的收入数据
				const currentYearData = this.workloadData.income.filter(item => item.year === currentYear);
				const previousMonthYearData = this.workloadData.income.filter(item => item.year === previousMonthYear);
				const lastYearData = this.workloadData.income.filter(item => item.year === lastYearSameYear);

				let maxValue = 0;

				// 统计当前月
				let currentMonthTotal = 0;
				currentYearData.forEach(item => {
					currentMonthTotal += item[`month_${currentMonth}`] || 0;
				});
				maxValue = Math.max(maxValue, currentMonthTotal);

				// 统计上个月
				let previousMonthTotal = 0;
				previousMonthYearData.forEach(item => {
					previousMonthTotal += item[`month_${previousMonth}`] || 0;
				});
				maxValue = Math.max(maxValue, previousMonthTotal);

				// 统计去年同月
				let lastYearSameMonthTotal = 0;
				lastYearData.forEach(item => {
					lastYearSameMonthTotal += item[`month_${lastYearSameMonth}`] || 0;
				});
				maxValue = Math.max(maxValue, lastYearSameMonthTotal);

				this.incomeChartData = [{
					quarter: `${currentMonth}月`,
					currentQuarter: currentMonthTotal,
					previousQuarter: previousMonthTotal,
					lastYearSame: lastYearSameMonthTotal,
					currentQuarterName: `${currentMonth}月`,
					currentQuarterYear: currentYear,
					previousQuarterName: `${previousMonth}月`,
					previousQuarterYear: previousMonthYear,
					lastYearSameQuarterName: `去年${lastYearSameMonth}月`
				}];

				this.maxIncomeValue = maxValue;
			},

			// 生成收入图表（季度模式）
			generateIncomeChart(currentQuarter, previousQuarter, previousYear, lastYearSameQuarter, lastYearSameYear) {
				// 获取各年度的收入数据
				const currentYearData = this.workloadData.income.filter(item => item.year === this.visualQueryYear);
				const previousYearData = this.workloadData.income.filter(item => item.year === previousYear);
				const lastYearData = this.workloadData.income.filter(item => item.year === lastYearSameYear);

				let maxValue = 0;

				// 统计当前季度
				let currentQuarterTotal = 0;
				currentYearData.forEach(item => {
					currentQuarter.months.forEach(month => {
						currentQuarterTotal += item[`month_${month}`] || 0;
					});
				});
				maxValue = Math.max(maxValue, currentQuarterTotal);

				// 统计上个季度
				let previousQuarterTotal = 0;
				previousYearData.forEach(item => {
					previousQuarter.months.forEach(month => {
						previousQuarterTotal += item[`month_${month}`] || 0;
					});
				});
				maxValue = Math.max(maxValue, previousQuarterTotal);

				// 统计去年同期
				let lastYearSameQuarterTotal = 0;
				lastYearData.forEach(item => {
					lastYearSameQuarter.months.forEach(month => {
						lastYearSameQuarterTotal += item[`month_${month}`] || 0;
					});
				});
				maxValue = Math.max(maxValue, lastYearSameQuarterTotal);

				this.incomeChartData = [{
					quarter: currentQuarter.name,
					currentQuarter: currentQuarterTotal,
					previousQuarter: previousQuarterTotal,
					lastYearSame: lastYearSameQuarterTotal,
					currentQuarterName: currentQuarter.name,
					currentQuarterYear: this.visualQueryYear,
					previousQuarterName: previousQuarter.name,
					previousQuarterYear: previousYear,
					lastYearSameQuarterName: lastYearSameQuarter.name
				}];

				this.maxIncomeValue = maxValue;
			},

			// 生成项目收入图表
			generateProjectIncomeChart(selectedQuarter) {
				if (!selectedQuarter) {
					this.projectIncomeChartData = [];
					this.maxProjectIncome = 0;
					return;
				}

				// 获取选中年度的收入数据
				const currentYearData = this.workloadData.income.filter(item => item.year === this.projectQueryYear);

				// 按项目统计收入
				const projectMap = new Map();

				// 统计选中季度的所有月份
				const quarterMonths = selectedQuarter.months;

				currentYearData.forEach(item => {
					const projectName = item.project_name;
					if (!projectMap.has(projectName)) {
						projectMap.set(projectName, 0);
					}

					// 累加季度的收入
					quarterMonths.forEach(month => {
						const monthValue = item[`month_${month}`] || 0;
						projectMap.set(projectName, projectMap.get(projectName) + monthValue);
					});
				});

				// 转换为数组并按收入降序排序
				const chartData = Array.from(projectMap, ([projectName, income]) => ({
					projectName,
					income
				})).sort((a, b) => b.income - a.income);

				// 计算最大收入
				const maxIncome = chartData.length > 0 ? Math.max(...chartData.map(item => item.income)) : 0;

				this.projectIncomeChartData = chartData;
				this.maxProjectIncome = maxIncome;
			},

			// 生成项目样品测定量饼状图
			generateProjectSamplePieChart(selectedQuarter) {
				if (!selectedQuarter) {
					this.projectSampleChartData = [];
					return;
				}

				// 获取选中年度的样品测定量数据
				const currentYearData = this.workloadData.sample.filter(item => item.year === this.projectQueryYear);

				// 按项目统计样品数量
				const projectMap = new Map();

				// 统计选中季度的所有月份
				const quarterMonths = selectedQuarter.months;

				currentYearData.forEach(item => {
					const projectName = item.project_name;
					if (!projectMap.has(projectName)) {
						projectMap.set(projectName, 0);
					}

					// 累加季度的样品数量
					quarterMonths.forEach(month => {
						const monthValue = item[`month_${month}`] || 0;
						projectMap.set(projectName, projectMap.get(projectName) + monthValue);
					});
				});

				// 转换为数组并按数量降序排序
				let projectArray = Array.from(projectMap, ([projectName, count]) => ({
					projectName,
					count
				})).sort((a, b) => b.count - a.count);

				// 只保留前10名，其余合并为"其他"
				if (projectArray.length > 10) {
					const top10 = projectArray.slice(0, 10);
					const others = projectArray.slice(10);
					const othersCount = others.reduce((sum, item) => sum + item.count, 0);

					if (othersCount > 0) {
						top10.push({
							projectName: '其他',
							count: othersCount
						});
					}
					projectArray = top10;
				}

				const totalCount = projectArray.reduce((sum, item) => sum + item.count, 0);

				if (totalCount === 0) {
					this.projectSampleChartData = [];
					return;
				}

				// 计算每个项目的百分比和饼图路径
				let currentAngle = -90; // 从顶部开始（-90度）

				const chartData = projectArray.map(item => {
					const percentage = (item.count / totalCount) * 100;
					const angle = (percentage / 100) * 360;

					// 计算饼图扇形路径
					const startAngle = currentAngle * Math.PI / 180;
					const endAngle = (currentAngle + angle) * Math.PI / 180;
					const radius = 100;

					const x1 = radius * Math.cos(startAngle);
					const y1 = radius * Math.sin(startAngle);
					const x2 = radius * Math.cos(endAngle);
					const y2 = radius * Math.sin(endAngle);

					const largeArcFlag = angle > 180 ? 1 : 0;

					const path = `M 0 0 L ${x1} ${y1} A ${radius} ${radius} 0 ${largeArcFlag} 1 ${x2} ${y2} Z`;

					// 计算扇形中间角度
					const midAngle = (currentAngle + angle / 2) * Math.PI / 180;

					// 引导线起点（从饼图边缘外侧开始，增加3px间隙）
					const lineStartRadius = radius + 3;
					const lineStartX = lineStartRadius * Math.cos(midAngle);
					const lineStartY = lineStartRadius * Math.sin(midAngle);

					// 判断标签在左侧还是右侧
					const isRightSide = Math.cos(midAngle) > 0;

					// 引导线终点（直线延伸）
					const lineLength = 85; // 引导线长度
					const lineEndX = lineStartX + (isRightSide ? lineLength : -lineLength);
					const lineEndY = lineStartY;

					// 标签位置（在直线末端）
					const labelX = isRightSide ? lineEndX + 5 : lineEndX - 5;
					const labelY = lineEndY + 4; // 稍微向下偏移，使文字垂直居中
					const labelAlign = isRightSide ? 'start' : 'end';

					currentAngle += angle;

					return {
						projectName: item.projectName,
						count: item.count,
						percentage: percentage,
						path: path,
						lineStartX: lineStartX,
						lineStartY: lineStartY,
						lineEndX: lineEndX,
						lineEndY: lineEndY,
						labelX: labelX,
						labelY: labelY,
						labelAlign: labelAlign,
						hovered: false
					};
				});

				// 调整标签位置以防止重叠
				this.projectSampleChartData = this.adjustPieChartLabels(chartData);
			},

			// 调整饼图标签位置以防止重叠
			adjustPieChartLabels(chartData) {
				if (chartData.length === 0) return chartData;

				const minDistance = 18; // 最小垂直间距（像素）

				// 分别处理左侧和右侧的标签
				const leftLabels = chartData.filter(item => item.labelAlign === 'end').sort((a, b) => a.labelY - b.labelY);
				const rightLabels = chartData.filter(item => item.labelAlign === 'start').sort((a, b) => a.labelY - b.labelY);

				// 调整标签位置的函数
				const adjustLabels = (labels) => {
					for (let i = 1; i < labels.length; i++) {
						const prevLabel = labels[i - 1];
						const currLabel = labels[i];
						const distance = currLabel.labelY - prevLabel.labelY;

						if (distance < minDistance) {
							// 如果距离太近，向下移动当前标签
							currLabel.labelY = prevLabel.labelY + minDistance;
							currLabel.lineEndY = currLabel.labelY - 4;
						}
					}
				};

				adjustLabels(leftLabels);
				adjustLabels(rightLabels);

				return chartData;
			},

			// 计算样品柱子高度
			getBarHeight(value) {
				if (!this.maxQuarterlyValue || this.maxQuarterlyValue === 0) {
					return 30;
				}
				if (value === 0) {
					return 30; // 0值显示最小高度
				}
				// 最大高度300px（留出10px空间）
				const height = (value / this.maxQuarterlyValue) * 300;
				return Math.max(30, height); // 最小高度30px
			},

			// 计算收入柱子高度
			getIncomeBarHeight(value) {
				if (!this.maxIncomeValue || this.maxIncomeValue === 0) {
					return 30;
				}
				if (value === 0) {
					return 30; // 0值显示最小高度
				}
				// 最大高度300px（留出10px空间）
				const height = (value / this.maxIncomeValue) * 300;
				return Math.max(30, height); // 最小高度30px
			},

			// 计算项目柱子宽度（百分比）
			getProjectBarWidth(value) {
				if (!this.maxProjectIncome || this.maxProjectIncome === 0) {
					return 0;
				}
				if (value === 0) {
					return 0;
				}
				// 返回相对于最大值的百分比
				return (value / this.maxProjectIncome) * 100;
			},

			// 格式化金额
			formatMoney(value) {
				if (!value || value === 0) return '0';
				// 转换为千分位格式
				return value.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
			},

			// 生成总体监测情况汇报图表
			generateOverallChart() {
				if (!this.overallQueryYear) {
					this.$message.warning('请选择年度');
					return;
				}
				if (!this.overallMonthStart || !this.overallMonthEnd) {
					this.$message.warning('请选择月份区间');
					return;
				}
				if (this.overallMonthStart > this.overallMonthEnd) {
					this.$message.warning('起始月份不能大于结束月份');
					return;
				}

				// 获取选中年度的数据
				const sampleData = this.workloadData.sample.filter(item => item.year === this.overallQueryYear);
				const incomeData = this.workloadData.income.filter(item => item.year === this.overallQueryYear);

				const chartData = [];
				let maxSample = 0;
				let maxIncome = 0;

				// 遍历月份区间
				for (let month = this.overallMonthStart; month <= this.overallMonthEnd; month++) {
					// 统计该月的样品测定量总数
					let sampleCount = 0;
					sampleData.forEach(item => {
						sampleCount += item[`month_${month}`] || 0;
					});
					maxSample = Math.max(maxSample, sampleCount);

					// 统计该月的收入总数
					let income = 0;
					incomeData.forEach(item => {
						income += item[`month_${month}`] || 0;
					});
					maxIncome = Math.max(maxIncome, income);

					chartData.push({
						month: month,
						sampleCount: sampleCount,
						income: income
					});
				}

				this.overallChartData = chartData;
				this.maxOverallSample = maxSample || 1; // 避免除以0
				this.maxOverallIncome = maxIncome || 1;

				if (chartData.length === 0) {
					this.$message.warning('所选月份区间没有数据');
				}
			},

			// 计算柱状图高度百分比
			getOverallBarHeight(value) {
				if (!this.maxOverallSample || this.maxOverallSample === 0) {
					return 5;
				}
				if (value === 0) {
					return 5;
				}
				// 返回相对于最大值的百分比（0-100%）
				const percentage = (value / this.maxOverallSample) * 100;
				return Math.max(5, percentage); // 最小5%，避免太小看不见
			},

			// 获取折线图的坐标点
			getOverallLinePoints() {
				if (this.overallChartData.length === 0) {
					return '';
				}

				// 如果只有一个点，需要特殊处理
				if (this.overallChartData.length === 1) {
					const y = 100 - ((this.overallChartData[0].income / this.maxOverallIncome) * 100);
					return `50,${y}`;
				}

				const points = this.overallChartData.map((item, index) => {
					// X坐标：根据索引均匀分布在0-100%之间
					const x = (index / (this.overallChartData.length - 1)) * 100;
					// Y坐标：根据收入值计算，需要反转（SVG坐标系Y轴向下）
					const y = 100 - ((item.income / this.maxOverallIncome) * 100);
					return `${x},${y}`;
				});

				return points.join(' ');
			},

			// 获取折线图的数据点（用于显示圆点和标签）
			getOverallDataPoints() {
				if (this.overallChartData.length === 0) {
					return [];
				}

				// 如果只有一个点，特殊处理
				if (this.overallChartData.length === 1) {
					const y = 100 - ((this.overallChartData[0].income / this.maxOverallIncome) * 100);
					return [{
						x: 50,
						y: y,
						value: this.overallChartData[0].income
					}];
				}

				return this.overallChartData.map((item, index) => {
					const x = (index / (this.overallChartData.length - 1)) * 100;
					const y = 100 - ((item.income / this.maxOverallIncome) * 100);
					return {
						x: x,
						y: y,
						value: item.income
					};
				});
			},

			// 导出图表为图片
			async exportChartAsImage(type) {
				let chartId, chartName, fileName;
				const quarterNames = ['第一季度', '第二季度', '第三季度', '第四季度'];

				if (type === 'sample') {
					chartId = 'sampleChart';
					chartName = '样品测定量季度对比';
					fileName = `${chartName}_${this.visualQueryYear}年_${this.visualMonthStart}-${this.visualMonthEnd}月.png`;
				} else if (type === 'income') {
					chartId = 'incomeChart';
					chartName = '收入季度对比';
					fileName = `${chartName}_${this.visualQueryYear}年_${this.visualMonthStart}-${this.visualMonthEnd}月.png`;
				} else if (type === 'overall') {
					chartId = 'overallChart';
					chartName = '样品测定量与收入月度趋势';
					fileName = `${chartName}_${this.overallQueryYear}年_${this.overallMonthStart}-${this.overallMonthEnd}月.png`;
				} else if (type === 'project') {
					chartId = 'projectChart';
					chartName = '各项目总收入对比';
					fileName = `${chartName}_${this.projectQueryYear}年_${quarterNames[this.projectQueryQuarter - 1]}.png`;
				} else if (type === 'pie') {
					chartId = 'pieChart';
					chartName = '各项目样品测定量占比';
					fileName = `${chartName}_${this.projectQueryYear}年_${quarterNames[this.projectQueryQuarter - 1]}.png`;
				} else if (type === 'criticalCompare') {
					chartId = 'criticalCompareChart';
					chartName = '危急值季度对比';
					fileName = `${chartName}_${this.criticalQueryYear}年_${quarterNames[this.criticalQueryQuarter - 1]}.png`;
				} else if (type === 'criticalProject') {
					chartId = 'criticalProjectChart';
					chartName = '当前季度危急值项目分布';
					fileName = `${chartName}_${this.criticalQueryYear}年_${quarterNames[this.criticalQueryQuarter - 1]}.png`;
				}
				const element = document.getElementById(chartId);

				if (!element) {
					this.$message.error('图表元素未找到');
					return;
				}

				try {
					this.$message.info('正在生成图片，请稍候...');

					// 使用html2canvas将DOM元素转换为canvas
					const canvas = await html2canvas(element, {
						backgroundColor: '#ffffff',
						scale: 2, // 提高清晰度
						logging: false,
						useCORS: true
					});

					// 将canvas转换为图片并下载
					canvas.toBlob((blob) => {
						const url = URL.createObjectURL(blob);
						const link = document.createElement('a');
						link.href = url;
						link.download = fileName;
						document.body.appendChild(link);
						link.click();
						document.body.removeChild(link);
						URL.revokeObjectURL(url);
						this.$message.success('图片已导出');
					});
				} catch (error) {
					console.error('导出图片失败:', error);
					this.$message.error('导出图片失败');
				}
			},
			
			beforeWorkloadUpload(file) {
				// 验证年份是否选择
				if (!this.workloadYear) {
					this.$message.error('请先选择导入数据的年份');
					return false;
				}

				// 验证文件类型
				const isExcel = file.type === 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' ||
								file.type === 'application/vnd.ms-excel';
				if (!isExcel) {
					this.$message.error('只能上传Excel文件');
					return false;
				}

				// 验证文件大小
				const isLt10M = file.size / 1024 / 1024 < 10;
				if (!isLt10M) {
					this.$message.error('文件大小不能超过10MB');
					return false;
				}

				return true;
			},
			
			async handleWorkloadUploadSuccess(response, file, fileList) {
				if (response.success) {
					this.$message.success('文件上传成功！');
					await this.loadWorkloadData();
				} else {
					this.$message.error(response.message || '文件上传失败');
				}
			},
			
			handleWorkloadUploadError(err, file, fileList) {
				this.$message.error('文件上传失败：' + (err.message || '未知错误'));
			},
			
			handleWorkloadPageChange(type, page) {
				this.workloadPagination[type].currentPage = page;
			},
			
			async deleteWorkloadData(type) {
				try {
					await this.$confirm('确定要删除所有' + this.getWorkloadTypeName(type) + '数据吗？', '警告', {
						confirmButtonText: '确定',
						cancelButtonText: '取消',
						type: 'warning'
					});
					
					const response = await axios.delete(`/api/workload/data/${type}`, { withCredentials: true });
					if (response.data.success) {
						this.$message.success('删除成功');
						this.workloadData[type] = [];
						this.workloadPagination[type].currentPage = 1;
					} else {
						this.$message.error(response.data.message || '删除失败');
					}
				} catch (error) {
					if (error !== 'cancel') {
						this.$message.error('删除失败：' + (error.message || '未知错误'));
					}
				}
			},
			
			getWorkloadTypeName(type) {
				const names = {
					sample: '样品测定量',
					income: '收入',
					critical: '危急值'
				};
				return names[type] || type;
			},
			
			async changePassword() {
				try {
					// 表单验证
					const valid = await new Promise((resolve) => {
						this.$refs.passwordForm.validate((valid) => {
							resolve(valid);
						});
					});
					
					if (!valid) {
						return;
					}
					
					this.passwordChangeLoading = true;
					
					const response = await axios.post('/api/auth/change-password', {
						currentPassword: this.passwordForm.currentPassword,
						newPassword: this.passwordForm.newPassword
					}, {
						withCredentials: true
					});
					
					this.$message.success('密码修改成功');
					this.showPasswordDialog = false;
					this.resetPasswordForm();
					
				} catch (error) {
					console.error('密码修改失败:', error);
					if (error.response && error.response.data && error.response.data.message) {
						this.$message.error('密码修改失败: ' + error.response.data.message);
					} else {
						this.$message.error('密码修改失败，请稍后重试');
					}
				} finally {
					this.passwordChangeLoading = false;
				}
			},
			
			// 图表相关辅助方法
			getMaxValue(chartData) {
				if (!chartData || chartData.length === 0) return 1;
				let max = 0;
				chartData.forEach(item => {
					max = Math.max(max, item.一般 || 0, item.严重 || 0);
				});
				return max || 1;
			},

			getPieColor(index) {
				const colors = [
					'#409EFF', '#67C23A', '#E6A23C', '#F56C6C', '#909399',
					'#66B1FF', '#85CE61', '#F0B860', '#F78989', '#B3B3B3',
					'#3A8EE6', '#5DAF34', '#CF9236', '#DD6161', '#82848A',
					'#5470C6', '#91CC75', '#FAC858', '#EE6666', '#73C0DE',
					'#3BA272', '#FC8452', '#9A60B4', '#EA7CCC', '#6395FA',
					'#62DAAB', '#657798', '#F6BD16', '#7262FD', '#78D3F8',
					'#9661BC', '#F6903D', '#008685', '#F08BB4', '#B6A2DE',
					'#5B8FF9', '#5AD8A6', '#5D7092', '#F6BD16', '#E86452',
					'#6DC8EC', '#945FB9', '#FF9845', '#1E9493', '#FF99C3'
				];
				return colors[index % colors.length];
			},
			
			getPieSlices(pieData) {
				if (!pieData || pieData.length === 0) return [];
				
				const total = pieData.reduce((sum, item) => sum + item.value, 0);
				if (total === 0) return [];
				
				let currentAngle = 0;
				const radius = 120;
				
				return pieData.map(item => {
					const angle = (item.value / total) * 2 * Math.PI;
					const startAngle = currentAngle;
					const endAngle = currentAngle + angle;
					
					const x1 = Math.cos(startAngle) * radius;
					const y1 = Math.sin(startAngle) * radius;
					const x2 = Math.cos(endAngle) * radius;
					const y2 = Math.sin(endAngle) * radius;
					
					const largeArcFlag = angle > Math.PI ? 1 : 0;
					
					const path = [
						'M', 0, 0,
						'L', x1, y1,
						'A', radius, radius, 0, largeArcFlag, 1, x2, y2,
						'Z'
					].join(' ');
					
					currentAngle = endAngle;
					
					return { path };
				});
			}
		}
	});
	</script>
</body>
</html>
