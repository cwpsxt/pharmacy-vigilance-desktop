														style="height: 100%; display: flex; align-items: flex-end; justify-content: space-around;">
														<div v-for="item in statisticsData.chart_data" :key="item.name"
															style="flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: flex-end; margin: 0 5px;">
															<!-- 数值标签 -->
