			},
			
			async loadStatistics() {
				this.statisticsLoading = true;
				try {
					const params = {
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					};
					const res = await axios.get('/api/data/analysis/statistics', { 
						params, 
						withCredentials: true 
					});
					this.statisticsData = res.data;
					
					// 处理月度统计表格数据
					this.processMonthlyRatioData();
				} catch (e) {
					this.$message.error('加载统计数据失败: ' + (e.response?.data?.message || '未知错误'));
					this.statisticsData = {
						severity_stats: [],
						month_stats: [],
						chart_data: [],
						total_count: 0,
						monthly_ratio_stats: []
					};
					this.processMonthlyRatioData();
				} finally {
					this.statisticsLoading = false;
				}
			},
			
			async loadReportDetails() {
				this.reportDetailsLoading = true;
				try {
					const params = {
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					};
					const res = await axios.get('/api/data/analysis/report-details', { 
						params, 
						withCredentials: true 
					});
					this.reportDetailsData = res.data;
					
					// 处理表格数据
					this.processReportDetailsTableData();
				} catch (e) {
					this.$message.error('加载上报明细失败: ' + (e.response?.data?.message || '未知错误'));
					this.reportDetailsData = {
						report_details: [],
						department_subtotals: {},
						total_stats: {}
					};
					this.processReportDetailsTableData();
				} finally {
					this.reportDetailsLoading = false;
				}
			},
			
			processReportDetailsTableData() {
				const tableData = [];
				const details = this.reportDetailsData.report_details || [];
				const subtotals = this.reportDetailsData.department_subtotals || {};
				const totalStats = this.reportDetailsData.total_stats || {};
				
				// 调试信息
				console.log('totalStats:', totalStats);
				console.log('subtotals:', subtotals);
				console.log('details length:', details.length);
				
				// 按科室分组
				const departmentGroups = {};
				details.forEach(detail => {
					if (!departmentGroups[detail.department]) {
						departmentGroups[detail.department] = [];
					}
					departmentGroups[detail.department].push(detail);
				});
				
				// 生成表格数据
				Object.keys(departmentGroups).sort().forEach(department => {
					// 添加科室内的详细数据
					departmentGroups[department].forEach(detail => {
						tableData.push({
							department: detail.department,
							profession: detail.profession,
							reporter_name: detail.reporter_name,
							total: detail.total,
							一般: detail.一般,
							严重: detail.严重,
							新的_一般: detail.新的_一般,
							新的_严重: detail.新的_严重,
							isSubtotal: false,
							isTotal: false
						});
					});
					
					// 添加科室小计
					if (subtotals[department]) {
						tableData.push({
							department: '小计',
							profession: '',
							reporter_name: '',
							total: subtotals[department].total,
							一般: subtotals[department].一般,
							严重: subtotals[department].严重,
							新的_一般: subtotals[department].新的_一般,
							新的_严重: subtotals[department].新的_严重,
							isSubtotal: true,
							isTotal: false
						});
					}
				});
				
				// 添加合计行 - 从已生成的表格数据中找到小计行来计算合计
				const subtotalRows = tableData.filter(row => row.isSubtotal);
				
				if (subtotalRows.length > 0) {
					// 从小计行计算合计
					let grandTotal = 0;
					let grandGeneral = 0;
					let grandSevere = 0;
					let grandNewGeneral = 0;
					let grandNewSevere = 0;
					
					subtotalRows.forEach(row => {
						grandTotal += row.total || 0;
						grandGeneral += row.一般 || 0;
						grandSevere += row.严重 || 0;
						grandNewGeneral += row.新的_一般 || 0;
						grandNewSevere += row.新的_严重 || 0;
					});
					
					// 合计行只显示总计数量，不需要累加所有分类
					const finalTotal = grandTotal;
					
					console.log('从小计行计算合计:', {
						subtotalRows: subtotalRows.length,
						grandTotal,
						grandGeneral,
						grandSevere,
						grandNewGeneral,
						grandNewSevere,
						finalTotal
					});
					
					tableData.push({
						department: '合计',
						profession: '',
						reporter_name: '',
						total: finalTotal,
						一般: '',
						严重: '',
						新的_一般: '',
						新的_严重: '',
						isSubtotal: false,
						isTotal: true
					});
				} else if (totalStats.total !== undefined) {
					// 如果没有小计行，使用totalStats
					const finalTotal = totalStats.total || 0;
					
					console.log('使用totalStats计算合计:', {
						totalStats,
						finalTotal
					});
					
					tableData.push({
						department: '合计',
						profession: '',
						reporter_name: '',
						total: finalTotal,
						一般: '',
						严重: '',
						新的_一般: '',
						新的_严重: '',
						isSubtotal: false,
						isTotal: true
					});
				}
				
				this.reportDetailsTableData = tableData;
			},
			
			exportReportDetails() {
				try {
					// 构建导出URL
					const params = new URLSearchParams({
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					});
					
					const exportUrl = `/api/data/analysis/export-report-details?${params.toString()}`;
					
					// 创建隐藏的下载链接
					const link = document.createElement('a');
					link.href = exportUrl;
					link.style.display = 'none';
					document.body.appendChild(link);
					link.click();
					document.body.removeChild(link);
					
					this.$message.success('上报明细导出任务已开始，请稍候下载');
				} catch (e) {
					this.$message.error('导出上报明细失败: ' + (e.message || '未知错误'));
				}
			},
			
			// 处理月度统计表格数据
			processMonthlyRatioData() {
				const monthlyData = this.statisticsData.monthly_ratio_stats || [];
				
				// 生成月份列（202501-202512）
				this.monthColumns = [];
				for (let i = 1; i <= 12; i++) {
					this.monthColumns.push(`2025${i.toString().padStart(2, '0')}`);
				}
				
				// 创建数据映射
				const dataMap = {};
				monthlyData.forEach(item => {
					dataMap[item.month] = item;
				});
				
				// 创建表格数据
				const totalRow = { type: '总计', total: 0 };
				const seriousRow = { type: '严重的', total: 0 };
				const seriousRatioRow = { type: '占比', total: '' };
				const seriousPlusNewRow = { type: '严重的+新的', total: 0 };
				const seriousPlusNewRatioRow = { type: '占比', total: '' };
				
				// 填充每个月的数据
				this.monthColumns.forEach(month => {
					const data = dataMap[month];
					if (data) {
						totalRow[month] = data.total;
						seriousRow[month] = data.serious_count;
						seriousRatioRow[month] = data.serious_ratio + '%';
						seriousPlusNewRow[month] = data.new_serious_count;
						seriousPlusNewRatioRow[month] = data.new_serious_ratio + '%';
						
						// 累计总数
						totalRow.total += data.total;
						seriousRow.total += data.serious_count;
						seriousPlusNewRow.total += data.new_serious_count;
					} else {
						totalRow[month] = 0;
						seriousRow[month] = 0;
						seriousRatioRow[month] = '0.00%';
						seriousPlusNewRow[month] = 0;
						seriousPlusNewRatioRow[month] = '0.00%';
					}
				});
				
				// 计算总占比
				seriousRatioRow.total = totalRow.total > 0 ? 
					((seriousRow.total / totalRow.total * 100).toFixed(2) + '%') : '0.00%';
				seriousPlusNewRatioRow.total = totalRow.total > 0 ? 
					((seriousPlusNewRow.total / totalRow.total * 100).toFixed(2) + '%') : '0.00%';
				
				// 设置表格数据
				this.monthlyRatioTableData = [
					totalRow,
					seriousRow,
					seriousRatioRow,
					seriousPlusNewRow,
					seriousPlusNewRatioRow
				];
			},
			
			// 获取百分比颜色
			getPercentageColor(type, value) {
				if (type === '占比' && value && value !== '0.00%') {
					return '#F56C6C'; // 红色
				}
				return '#333';
			},
			
			getTypeColor(type) {
				const colorMap = {
					'总计': '#606266',      // 深灰色
					'一般': '#67C23A',      // 绿色
					'严重': '#F56C6C',      // 红色
					'新的+一般': '#409EFF',  // 蓝色
					'新的+严重': '#E6A23C'   // 橙色
				};
				return colorMap[type] || '#909399'; // 默认灰色
			},

			getChartHeight(value) {
				// 计算图表高度百分比
				if (!this.statisticsData.chart_data || this.statisticsData.chart_data.length === 0) {
					return 0;
				}
				// 找出最大值
				const maxValue = Math.max(...this.statisticsData.chart_data.map(item => item.value));
				if (maxValue === 0) {
					return 0;
				}
				// 计算百分比，最小20%，最大90%
				const percentage = (value / maxValue) * 90;
				return Math.max(20, percentage);
			},
			
			async loadRewardCalculation() {
				this.rewardCalculationLoading = true;
				try {
					const params = {
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					};
					const res = await axios.get('/api/data/analysis/reward-calculation', { 
						params, 
						withCredentials: true 
					});
					this.rewardCalculationData = res.data;
					
					// 处理表格数据
					this.processRewardCalculationTableData();
				} catch (e) {
					this.$message.error('加载奖励计算数据失败: ' + (e.response?.data?.message || '未知错误'));
					this.rewardCalculationData = {
						reward_details: [],
						department_subtotals: {},
						total_stats: {}
					};
					this.processRewardCalculationTableData();
				} finally {
					this.rewardCalculationLoading = false;
				}
			},
			
			processRewardCalculationTableData() {
				const tableData = [];
				const details = this.rewardCalculationData.reward_details || [];
				const subtotals = this.rewardCalculationData.department_subtotals || {};
				const totalStats = this.rewardCalculationData.total_stats || {};
				
				// 按科室分组
				const departmentGroups = {};
				details.forEach(detail => {
					if (!departmentGroups[detail.department]) {
						departmentGroups[detail.department] = [];
					}
					departmentGroups[detail.department].push(detail);
				});
				
				// 生成表格数据
				Object.keys(departmentGroups).sort().forEach(department => {
					// 添加科室内的详细数据
					departmentGroups[department].forEach(detail => {
						tableData.push({
							department: detail.department,
							profession: detail.profession,
							reporter_name: detail.reporter_name,
							一般: detail.一般,
							奖励_一般: detail.奖励_一般,
							严重: detail.严重,
							奖励_严重: detail.奖励_严重,
							新的_一般: detail.新的_一般,
							奖励_新的一般: detail.奖励_新的一般,
							新的_严重: detail.新的_严重,
							奖励_新的严重: detail.奖励_新的严重,
							个人奖励合计: detail.个人奖励合计,
							isSubtotal: false,
							isTotal: false
						});
					});
					
					// 添加科室小计
					if (subtotals[department]) {
						tableData.push({
							department: '小计',
							profession: '',
							reporter_name: '',
							一般: subtotals[department].一般,
							奖励_一般: subtotals[department].奖励_一般,
							严重: subtotals[department].严重,
							奖励_严重: subtotals[department].奖励_严重,
							新的_一般: subtotals[department].新的_一般,
							奖励_新的一般: subtotals[department].奖励_新的一般,
							新的_严重: subtotals[department].新的_严重,
							奖励_新的严重: subtotals[department].奖励_新的严重,
							个人奖励合计: subtotals[department].个人奖励合计,
							isSubtotal: true,
							isTotal: false
						});
					}
				});
				
				// 添加合计行
				if (totalStats.一般 !== undefined) {
					tableData.push({
						department: '合计',
						profession: '',
						reporter_name: '',
						一般: '',
						奖励_一般: '',
						严重: '',
						奖励_严重: '',
						新的_一般: '',
						奖励_新的一般: '',
						新的_严重: '',
						奖励_新的严重: '',
						个人奖励合计: totalStats.个人奖励合计,
						isSubtotal: false,
						isTotal: true
					});
				}
				
				this.rewardCalculationTableData = tableData;
			},
			
