										<div slot="header" style="display: flex; justify-content: space-between; align-items: center;">
											<span>发生不良反应的药品统计汇总</span>
											<el-button type="success" icon="el-icon-download" @click="exportDrugSummary" :loading="drugSummaryLoading">
												导出Excel
											</el-button>
										</div>
										<el-table :data="drugSummaryTableData" v-loading="drugSummaryLoading" style="width: 100%" stripe border>
											<el-table-column type="index" label="序号" width="60" align="center"></el-table-column>
											<el-table-column prop="drug_name" label="通用名称" min-width="150" align="center">
												<template slot-scope="scope">
													<span :style="{ fontWeight: scope.row.isTotal ? 'bold' : 'normal' }">
														{{ scope.row.drug_name }}
													</span>
												</template>
											</el-table-column>
											<el-table-column prop="manufacturer" label="生产厂家" min-width="200" align="center">
												<template slot-scope="scope">
													<span :style="{ fontWeight: scope.row.isTotal ? 'bold' : 'normal' }">
														{{ scope.row.manufacturer }}
													</span>
												</template>
											</el-table-column>
											<el-table-column prop="严重" label="严重" width="80" align="center">
												<template slot-scope="scope">
													<span :style="{ fontWeight: scope.row.isTotal ? 'bold' : 'normal', color: scope.row.严重 > 0 ? '#F56C6C' : '#333' }">
														{{ scope.row.严重 || 0 }}
													</span>
												</template>
											</el-table-column>
											<el-table-column prop="一般" label="一般" width="80" align="center">
												<template slot-scope="scope">
													<span :style="{ fontWeight: scope.row.isTotal ? 'bold' : 'normal' }">
														{{ scope.row.一般 || 0 }}
													</span>
												</template>
											</el-table-column>
											<el-table-column prop="total" label="合计" width="80" align="center">
												<template slot-scope="scope">
													<span :style="{ fontWeight: 'bold', color: scope.row.isTotal ? '#409EFF' : '#E6A23C' }">
														{{ scope.row.total || 0 }}
													</span>
												</template>
											</el-table-column>
										</el-table>
									</el-card>
								</div>
								
								<!-- 图表展示 -->
								<div style="margin-bottom: 20px;" v-if="drugSummaryChartData.bar_chart || drugSummaryChartData.pie_chart">
									<el-row :gutter="20">
										<el-col :span="14">
											<el-card>
												<div slot="header">
													<span>前十名药品不良反应统计</span>
												</div>
												<div style="height: 450px; padding: 20px 10px;">
													<div v-if="drugSummaryChartData.bar_chart && drugSummaryChartData.bar_chart.length > 0" style="display: flex; width: 100%; height: 100%;">
														<div v-for="(item, index) in drugSummaryChartData.bar_chart" :key="index"
															style="flex: 1; display: flex; flex-direction: column; align-items: center; margin: 0 3px;">
															<!-- 柱状图容器 - 固定高度 -->
															<div style="display: flex; align-items: flex-end; height: 320px; width: 100%;">
																<!-- 一般柱子 -->
																<div style="flex: 1; display: flex; flex-direction: column; align-items: center; margin-right: 2px;">
																	<div style="font-size: 10px; color: #67C23A; margin-bottom: 2px;">{{ item.一般 }}</div>
																	<div
																		:style="{
																			width: '100%',
																			height: Math.max(20, (item.一般 / getMaxValue(drugSummaryChartData.bar_chart)) * 280) + 'px',
																			backgroundColor: '#67C23A',
																			borderRadius: '2px 2px 0 0'
																		}"
																	></div>
																</div>
																<!-- 严重柱子 -->
																<div style="flex: 1; display: flex; flex-direction: column; align-items: center; margin-left: 2px;">
																	<div style="font-size: 10px; color: #F56C6C; margin-bottom: 2px;">{{ item.严重 }}</div>
																	<div
																		:style="{
																			width: '100%',
																			height: Math.max(20, (item.严重 / getMaxValue(drugSummaryChartData.bar_chart)) * 280) + 'px',
																			backgroundColor: '#F56C6C',
																			borderRadius: '2px 2px 0 0'
																		}"
																	></div>
																</div>
															</div>
															<!-- 药品名称 - 固定高度容器 -->
															<div style="font-size: 10px; color: #666; text-align: center; margin-top: 8px; word-wrap: break-word; word-break: keep-all; line-height: 1.3; max-width: 100px; white-space: normal; min-height: 40px; display: flex; align-items: flex-start; justify-content: center;">
																<span>{{ item.drug_name }}</span>
															</div>
														</div>
													</div>
													<div v-else style="color: #999; text-align: center;">暂无数据</div>
												</div>
												<!-- 图例 -->
												<div style="text-align: center; margin-top: 10px;">
													<span style="display: inline-block; width: 12px; height: 12px; background-color: #67C23A; margin-right: 5px; border-radius: 2px;"></span>
													<span style="font-size: 12px; margin-right: 20px;">一般</span>
													<span style="display: inline-block; width: 12px; height: 12px; background-color: #F56C6C; margin-right: 5px; border-radius: 2px;"></span>
													<span style="font-size: 12px;">严重</span>
												</div>
											</el-card>
										</el-col>
										<el-col :span="10">
											<el-card>
												<div slot="header">
													<span>药品不良反应分布</span>
												</div>
												<div style="height: 450px; display: flex; align-items: center; justify-content: center; position: relative; padding-right: 160px;">
													<div v-if="drugSummaryChartData.pie_chart && drugSummaryChartData.pie_chart.length > 0" style="position: relative; width: 300px; height: 300px;">
														<!-- 饼图 -->
														<svg width="300" height="300" style="position: absolute;">
															<g transform="translate(150,150)">
																<path v-for="(slice, index) in getPieSlices(drugSummaryChartData.pie_chart)" :key="index"
																	:d="slice.path"
																	:fill="getPieColor(index)"
																	:stroke="'white'"
																	:stroke-width="2"
																></path>
															</g>
														</svg>
														<!-- 图例 -->
														<div style="position: absolute; right: -150px; top: 50%; transform: translateY(-50%); width: 140px;">
															<div v-for="(item, index) in drugSummaryChartData.pie_chart" :key="index" style="margin-bottom: 10px; font-size: 11px; display: flex; align-items: flex-start;">
																<span :style="{ display: 'inline-block', width: '12px', height: '12px', backgroundColor: getPieColor(index), marginRight: '6px', borderRadius: '2px', flexShrink: 0, marginTop: '2px' }"></span>
																<div style="line-height: 1.4; word-wrap: break-word; word-break: keep-all; white-space: normal;">
																	<div style="font-weight: 500;">{{ item.name }}</div>
																	<div style="color: #666; font-size: 10px;">{{ item.value }}例</div>
																</div>
															</div>
														</div>
													</div>
													<div v-else style="color: #999;">暂无数据</div>
												</div>
											</el-card>
										</el-col>
									</el-row>
								</div>
							</el-tab-pane>
						</el-tabs>
					</el-card>
				</div>
			</div>
		</div>
		
		<!-- 修改密码对话框 -->
		<el-dialog title="修改密码" :visible.sync="showPasswordDialog" width="400px" :close-on-click-modal="false">
			<el-form :model="passwordForm" :rules="passwordRules" ref="passwordForm" label-width="100px">
				<el-form-item label="当前密码" prop="currentPassword">
					<el-input type="password" v-model="passwordForm.currentPassword" placeholder="请输入当前密码" show-password></el-input>
				</el-form-item>
				<el-form-item label="新密码" prop="newPassword">
					<el-input type="password" v-model="passwordForm.newPassword" placeholder="请输入新密码" show-password></el-input>
				</el-form-item>
				<el-form-item label="确认密码" prop="confirmPassword">
					<el-input type="password" v-model="passwordForm.confirmPassword" placeholder="请再次输入新密码" show-password></el-input>
				</el-form-item>
			</el-form>
			<div slot="footer" class="dialog-footer">
				<el-button @click="cancelPasswordChange">取消</el-button>
				<el-button type="primary" @click="changePassword" :loading="passwordChangeLoading">确认修改</el-button>
			</div>
		</el-dialog>
	</div>

	<script src="/static/libs/vue/vue.js"></script>
	<script src="/static/libs/axios/axios.min.js"></script>
	<script src="/static/libs/element-ui/index.js"></script>
	<script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
	<script>
	new Vue({
		el: '#app',
		data() {
			return {
				currentUser: { username: '' },
				activeMenu: 'dashboard',
				uploadUrl: '/api/data/upload',
				uploadHeaders: {},
				fileList: [],
				stats: {
					totalRecords: 0,
					todayImports: 0,
					pendingReviews: 0,
					alerts: 0,
					monthlyCount: 0,
					pharmacistCount: 0,
					newReports: 0,
					importTrend: [],
					severityDistribution: [],
					departmentDistribution: []
				},
				importHistory: [],
				// 数据管理相关
				reports: [],
				reportsLoading: false,
				searchText: '',
				severityFilter: '',
				currentPage: 1,
				pageSize: 20,
				totalRecords: 0,
				selectedReports: [],
				// 数据分析相关
				activeAnalysisTab: 'all',
				analysisFilters: {
					startMonth: '',
					endMonth: ''
				},
				availableMonths: [],
				fieldValues: {
					severity: [],
					suspect_concurrent: [],
					reporter_profession: [],
					manufacturer: [],
					generic_name: []
				},
				analysisData: { reports: [], total: 0 },
				analysisLoading: false,
				deduplicatedData: { reports: [], total: 0 },
				deduplicatedLoading: false,
				// 统计数据相关
				statisticsData: {
					severity_stats: [],
					month_stats: [],
					chart_data: [],
					total_count: 0,
					monthly_ratio_stats: []
				},
				// 月度占比统计表格数据
				monthlyRatioTableData: [],
				monthColumns: [],
				statisticsLoading: false,
				// 上报明细数据
				reportDetailsData: {
					report_details: [],
					department_subtotals: {},
					total_stats: {}
				},
				reportDetailsTableData: [],
				reportDetailsLoading: false,
				// 奖励计算数据
				rewardCalculationData: {
					reward_details: [],
					department_subtotals: {},
					total_stats: {}
				},
				rewardCalculationTableData: [],
				rewardCalculationLoading: false,
				// 药品汇总数据
				drugSummaryData: [],
				drugSummaryTableData: [],
				drugSummaryLoading: false,
				drugSummaryChartData: {
					bar_chart: [],
					pie_chart: []
				},
				// 合并导出
				mergedExportLoading: false,
				// 密码修改
				showPasswordDialog: false,
				passwordChangeLoading: false,
				// 工作量数据管理
				activeWorkloadTab: 'sample',
				workloadYear: new Date().getFullYear(),
				workloadData: {
					sample: [],
					income: [],
					critical: []
				},
				// 查询条件
				workloadQueryYear: null,
				workloadQueryMonthStart: null,
				workloadQueryMonthEnd: null,
				// 过滤后的数据
				filteredWorkloadData: {
					sample: [],
					income: [],
					critical: []
				},
				workloadPagination: {
					sample: { currentPage: 1, pageSize: 10 },
					income: { currentPage: 1, pageSize: 10 },
					critical: { currentPage: 1, pageSize: 10 }
				},
				// 数据可视化
				visualQueryYear: new Date().getFullYear(),
				visualMonthStart: 1,
				visualMonthEnd: 12,
				quarterlyChartData: [],
				maxQuarterlyValue: 0,
				incomeChartData: [],
				maxIncomeValue: 0,
				projectQueryYear: new Date().getFullYear(),
				projectQueryQuarter: Math.ceil((new Date().getMonth() + 1) / 3),
				projectIncomeChartData: [],
				maxProjectIncome: 0,
				projectSampleChartData: [],
				criticalQueryYear: new Date().getFullYear(),
				criticalQueryQuarter: Math.ceil((new Date().getMonth() + 1) / 3),
				criticalCompareChartData: [],
				maxCriticalValue: 0,
				criticalProjectChartData: [],
				// 总体监测情况汇报
				overallQueryYear: new Date().getFullYear(),
				overallMonthStart: 1,
				overallMonthEnd: 12,
				overallChartData: [],
				maxOverallSample: 0,
				maxOverallIncome: 0,
				passwordForm: {
					currentPassword: '',
					newPassword: '',
					confirmPassword: ''
				},
				passwordRules: {
					currentPassword: [
						{ required: true, message: '请输入当前密码', trigger: 'blur' }
					],
					newPassword: [
						{ required: true, message: '请输入新密码', trigger: 'blur' },
						{ min: 6, message: '密码长度不能少于6位', trigger: 'blur' }
					],
					confirmPassword: [
						{ required: true, message: '请再次输入新密码', trigger: 'blur' },
						{ validator: this.validateConfirmPassword, trigger: 'blur' }
					]
				}
			}
		},
		mounted() {
			this.checkAuth();
			this.loadStats();
			this.loadImportHistory();

			// 不设置默认月份，让用户自己选择区间
		},
		computed: {
			paginatedWorkloadData() {
				const result = {};
				['sample', 'income', 'critical'].forEach(type => {
					const data = this.filteredWorkloadData[type];
					const page = this.workloadPagination[type].currentPage;
					const pageSize = this.workloadPagination[type].pageSize;
					const start = (page - 1) * pageSize;
					const end = start + pageSize;
					result[type] = data.slice(start, end);
				});
				return result;
			}
		},
		methods: {
			async checkAuth() {
				try {
					const res = await axios.get('/api/auth/me', { withCredentials: true });
					if (!res.data.authenticated) {
						window.location.href = '/';
						return;
					}
					this.currentUser = res.data.user;
				} catch (e) {
					window.location.href = '/';
				}
			},
			
			async logout() {
				try {
					await axios.post('/api/auth/logout', {}, { withCredentials: true });
					this.$message.success('已退出登录');
					window.location.href = '/';
				} catch (e) {
					this.$message.error('退出登录失败');
				}
			},
			
			setActiveMenu(menu) {
				this.activeMenu = menu;
				if (menu === 'data-management') {
					this.loadReports();
				} else if (menu === 'workload-management') {
					this.loadWorkloadData();
				} else if (menu === 'data-analysis') {
					this.loadAnalysisMetadata();
					this.loadStatistics();
				}
			},
			
			async loadStats() {
				try {
					const res = await axios.get('/api/data/stats', { withCredentials: true });
					this.stats = res.data;
				} catch (e) {
					console.error('加载统计数据失败:', e);
					// 使用默认数据
					this.stats = {
						totalRecords: 0,
						todayImports: 0,
						pendingReviews: 0,
						alerts: 0,
						monthlyCount: 0,
						pharmacistCount: 0,
						newReports: 0,
						importTrend: [],
						severityDistribution: [],
						departmentDistribution: []
					};
				}
			},
			
			getProgressColor(percentage) {
				if (percentage < 30) {
					return '#F56C6C';
				} else if (percentage < 70) {
					return '#E6A23C';
				} else {
					return '#67C23A';
				}
			},
			
			getMaxDepartmentCount() {
				if (!this.stats.departmentDistribution || this.stats.departmentDistribution.length === 0) {
					return 1;
				}
				return Math.max(...this.stats.departmentDistribution.map(item => item.count));
			},
			
			getMaxImportCount() {
				if (!this.stats.importTrend || this.stats.importTrend.length === 0) {
					return 1;
				}
				return Math.max(...this.stats.importTrend.map(item => item.count));
			},
			
			getLinePointsPercent() {
				if (!this.stats.importTrend || this.stats.importTrend.length === 0) {
					return '';
				}
				
				const maxCount = this.getMaxImportCount();
				const stepWidth = 100 / (this.stats.importTrend.length - 1);
				
				const points = this.stats.importTrend.map((item, index) => {
					const x = index * stepWidth;
					const y = 100 - (item.count / maxCount) * 100; // 反转Y轴
					return `${x},${y}`;
				});
				
				return points.join(' ');
			},
			
			getFillAreaPoints() {
				if (!this.stats.importTrend || this.stats.importTrend.length === 0) {
					return '';
				}
				
				const maxCount = this.getMaxImportCount();
				const stepWidth = 100 / (this.stats.importTrend.length - 1);
				
				// 创建填充区域的点，从左下角开始，沿着折线，到右下角结束
				const linePoints = this.stats.importTrend.map((item, index) => {
					const x = index * stepWidth;
					const y = 100 - (item.count / maxCount) * 100;
					return `${x},${y}`;
				});
				
				// 添加底边的点
				const lastIndex = this.stats.importTrend.length - 1;
				const bottomPoints = [
					`${lastIndex * stepWidth},100`, // 右下角
					`0,100` // 左下角
				];
				
				return [...linePoints, ...bottomPoints].join(' ');
			},
			
			getDataPointsPercent() {
				if (!this.stats.importTrend || this.stats.importTrend.length === 0) {
					return [];
				}
				
				const maxCount = this.getMaxImportCount();
				const stepWidth = 100 / (this.stats.importTrend.length - 1);
				
				return this.stats.importTrend.map((item, index) => {
					const x = index * stepWidth;
					const y = 100 - (item.count / maxCount) * 100; // 反转Y轴
					return {
						x: x,
						y: y,
						value: item.count
					};
				});
			},
			
			async loadImportHistory() {
				try {
					const res = await axios.get('/api/data/import-history', { withCredentials: true });
					this.importHistory = res.data;
				} catch (e) {
					console.error('加载导入历史失败:', e);
					this.importHistory = [];
				}
			},
			
			beforeUpload(file) {
				const isExcel = file.type === 'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet' || 
				               file.type === 'application/vnd.ms-excel';
				const isLt10M = file.size / 1024 / 1024 < 10;
				
				if (!isExcel) {
					this.$message.error('只能上传 Excel 文件!');
					return false;
				}
				if (!isLt10M) {
					this.$message.error('上传文件大小不能超过 10MB!');
					return false;
				}
				return true;
			},
			
			handleUploadSuccess(response, file) {
				this.$message.success('文件上传成功!');
				this.loadImportHistory();
				this.loadStats();
			},
			
			handleUploadError(err, file) {
				this.$message.error('文件上传失败: ' + (err.message || '未知错误'));
			},
			
			// 数据管理相关方法
			async loadReports() {
				this.reportsLoading = true;
				try {
					const params = {
						page: this.currentPage,
						per_page: this.pageSize,
						search: this.searchText,
						severity: this.severityFilter
					};
					
					const res = await axios.get('/api/data/reports', { 
						params, 
						withCredentials: true 
					});
					
					this.reports = res.data.reports;
					this.totalRecords = res.data.total;
				} catch (e) {
					this.$message.error('加载数据失败: ' + (e.response?.data?.message || '未知错误'));
					this.reports = [];
					this.totalRecords = 0;
				} finally {
					this.reportsLoading = false;
				}
			},
			
			searchReports() {
				this.currentPage = 1;
				this.loadReports();
			},
			
			handleSizeChange(val) {
				this.pageSize = val;
				this.currentPage = 1;
				this.loadReports();
			},
			
			handleCurrentChange(val) {
				this.currentPage = val;
				this.loadReports();
			},

			handleSelectionChange(selection) {
				this.selectedReports = selection;
			},

			async batchDelete() {
				if (this.selectedReports.length === 0) {
					this.$message.warning('请选择要删除的报告');
					return;
				}

				try {
					await this.$confirm(`确定要删除选中的 ${this.selectedReports.length} 条报告吗？此操作不可恢复！`, '批量删除', {
						confirmButtonText: '确定',
						cancelButtonText: '取消',
						type: 'warning'
					});

					const ids = this.selectedReports.map(report => report.id);
					const res = await axios.post('/api/data/reports/batch-delete', { ids }, { withCredentials: true });

					this.$message.success(res.data.message);
					this.selectedReports = [];
					this.loadReports();
					this.loadStats();
				} catch (error) {
					if (error !== 'cancel') {
						this.$message.error('批量删除失败: ' + (error.response?.data?.message || '未知错误'));
					}
				}
			},

			async clearAllData() {
				try {
					await this.$confirm('确定要清空数据库中的所有数据吗？此操作不可恢复！', '一键清空', {
						confirmButtonText: '确定',
						cancelButtonText: '取消',
						type: 'error',
						confirmButtonClass: 'el-button--danger'
					});

					const res = await axios.post('/api/data/reports/clear-all', {}, { withCredentials: true });

					this.$message.success(res.data.message);
					this.selectedReports = [];
					this.reports = [];
					this.totalRecords = 0;
					this.loadStats();
				} catch (error) {
					if (error !== 'cancel') {
						this.$message.error('清空数据库失败: ' + (error.response?.data?.message || '未知错误'));
					}
				}
			},
			
			viewReport(report) {
				this.$alert(
					`<div style="text-align: left; line-height: 1.8;">
						<p><strong>报告表编码:</strong> ${report.report_code}</p>
						<p><strong>报告类型-新的:</strong> ${report.report_type_new || '无'}</p>
						<p><strong>报告类型-严重程度:</strong> ${report.severity}</p>
						<p><strong>病历号/门诊号:</strong> ${report.medical_record_no}</p>
						<p><strong>怀疑/并用:</strong> ${report.suspect_concurrent}</p>
						<p><strong>通用名称:</strong> ${report.generic_name}</p>
						<p><strong>生产厂家:</strong> ${report.manufacturer}</p>
						<p><strong>不良反应名称:</strong> ${report.adverse_reaction_name}</p>
						<p><strong>报告人职业:</strong> ${report.reporter_profession}</p>
						<p><strong>报告人签名:</strong> ${report.reporter_signature}</p>
						<p><strong>国家中心接收时间:</strong> ${this.formatDateTime(report.national_center_receive_time)}</p>
					</div>`,
					'报告详情',
					{
						dangerouslyUseHTMLString: true,
						customClass: 'report-detail-dialog'
					}
				);
			},
			
			formatDateTime(dateStr) {
				if (!dateStr) return '';
				const date = new Date(dateStr);
				return date.toLocaleString('zh-CN');
			},
			
			// 数据分析相关方法
			async loadAnalysisMetadata() {
				try {
					// 加载可用月份
					const monthsRes = await axios.get('/api/data/analysis/months', { withCredentials: true });
					this.availableMonths = monthsRes.data;
					
					// 加载各字段的值
					const fields = ['severity', 'suspect_concurrent', 'reporter_profession', 'manufacturer', 'generic_name'];
					for (const field of fields) {
						try {
							const res = await axios.get(`/api/data/analysis/field-values?field=${field}`, { withCredentials: true });
							this.fieldValues[field] = res.data;
						} catch (e) {
							console.error(`加载字段 ${field} 值失败:`, e);
						}
					}
					
					// 初始加载数据
					this.loadAnalysisData();
				} catch (e) {
					this.$message.error('加载分析元数据失败: ' + (e.response?.data?.message || '未知错误'));
				}
			},
			
			async loadAnalysisData() {
				this.analysisLoading = true;
				try {
					const params = { ...this.analysisFilters };
					const res = await axios.get('/api/data/analysis/data', { 
						params, 
						withCredentials: true 
					});
					this.analysisData = res.data;
					
					// 如果当前是去重标签页，也加载去重数据
					if (this.activeAnalysisTab === 'deduplicated') {
						this.loadDeduplicatedData();
					}
					
					// 如果当前是统计标签页，也加载统计数据
					if (this.activeAnalysisTab === 'statistics') {
						this.loadStatistics();
					}
				} catch (e) {
					this.$message.error('加载分析数据失败: ' + (e.response?.data?.message || '未知错误'));
					this.analysisData = { reports: [], total: 0 };
				} finally {
					this.analysisLoading = false;
				}
			},
			
			async loadDeduplicatedData() {
				this.deduplicatedLoading = true;
				try {
					const params = { ...this.analysisFilters };
					const res = await axios.get('/api/data/analysis/deduplicated', { 
						params, 
						withCredentials: true 
					});
					this.deduplicatedData = res.data;
				} catch (e) {
					this.$message.error('加载去重数据失败: ' + (e.response?.data?.message || '未知错误'));
					this.deduplicatedData = { reports: [], total: 0 };
				} finally {
					this.deduplicatedLoading = false;
				}
			},
			
			handleTabClick(tab) {
				if (tab.name === 'deduplicated' && this.deduplicatedData.reports.length === 0) {
					this.loadDeduplicatedData();
				} else if (tab.name === 'statistics') {
					this.loadStatistics();
				} else if (tab.name === 'report-details') {
					this.loadReportDetails();
				} else if (tab.name === 'reward-calculation') {
					this.loadRewardCalculation();
				} else if (tab.name === 'drug-summary') {
					this.loadDrugSummary();
				}
			},
			
			resetFilters() {
				this.analysisFilters = {
					startMonth: '',
					endMonth: ''
				};
				this.loadAnalysisData();
			},
			
			exportData(type) {
				try {
					// 构建导出URL
					const params = new URLSearchParams({
						...this.analysisFilters,
						type: type
					});
					
					const exportUrl = `/api/data/analysis/export?${params.toString()}`;
					
					// 创建隐藏的下载链接
					const link = document.createElement('a');
					link.href = exportUrl;
					link.style.display = 'none';
					document.body.appendChild(link);
					link.click();
					document.body.removeChild(link);
					
					this.$message.success('导出任务已开始，请稍候下载');
				} catch (e) {
					this.$message.error('导出失败: ' + (e.message || '未知错误'));
				}
			},
			
			exportStatistics() {
				try {
					// 构建导出URL
					const params = new URLSearchParams({
						startMonth: this.analysisFilters.startMonth,
						endMonth: this.analysisFilters.endMonth
					});
					
					const exportUrl = `/api/data/analysis/export-statistics?${params.toString()}`;
					
					// 创建隐藏的下载链接
					const link = document.createElement('a');
					link.href = exportUrl;
					link.style.display = 'none';
					document.body.appendChild(link);
