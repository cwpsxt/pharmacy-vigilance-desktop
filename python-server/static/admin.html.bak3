																{{ item.value }}
															</div>
															<!-- 柱状图 -->
															<div
																:style="{
																	width: '100%',
																	maxWidth: '80px',
																	height: getChartHeight(item.value) + '%',
																	backgroundColor: getTypeColor(item.name),
																	borderRadius: '4px 4px 0 0',
																	transition: 'height 0.3s ease',
																	minHeight: '30px',
																	display: 'flex',
																	alignItems: 'center',
																	justifyContent: 'center'
																}"
															></div>
															<!-- 类型标签 -->
															<div style="font-size: 12px; color: #666; margin-top: 8px; text-align: center; word-break: keep-all;">
																{{ item.name }}
															</div>
														</div>
													</div>
													<div v-else style="height: 100%; display: flex; align-items: center; justify-content: center; color: #999;">
